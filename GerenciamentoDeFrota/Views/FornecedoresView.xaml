<UserControl x:Class="GerenciamentoDeFrota.Views.FornecedoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <UserControl.Resources>

        <SolidColorBrush x:Key="CardBrush"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextStrong" Color="#1F2A37"/>
        <SolidColorBrush x:Key="TextSoft"   Color="#6B7280"/>
        <SolidColorBrush x:Key="LineBrush"  Color="#E5E7EB"/>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoft}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="CleanDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="42"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FBFBFD"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="2,2,2,14">
            <TextBlock Text="Cadastro de Fornecedores"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextStrong}"/>
            <TextBlock Text="Gerencie informações dos fornecedores e visualize a lista cadastrada."
                       Margin="0,4,0,0" FontSize="12"
                       Foreground="{StaticResource TextSoft}"/>
        </StackPanel>

        <!-- FORM -->
        <StackPanel Grid.Row="1">

            <!-- Card: Dados do Fornecedor -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Dados do Fornecedor"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextStrong}"
                               Margin="0,0,0,14"/>

                    <!-- Linha 1: CPF/CNPJ, Nome, Tel1, Tel2, Tel3 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="CPF / CNPJ" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtCpfCnpj"
                                     Text="{Binding CpfCnpj, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Nome do Fornecedor" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtNome"
                                     Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <TextBlock Text="Telefone 1" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtTelefone1"
                                     Text="{Binding Telefone1, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,10,0">
                            <TextBlock Text="Telefone 2" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtTelefone2"
                                     Text="{Binding Telefone2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Telefone 3" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtTelefone3"
                                     Text="{Binding Telefone3, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Linha 2: Email1, Email2, Email3, Ativo -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Email 1" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtEmail1"
                                     Text="{Binding Email1, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Email 2" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtEmail2"
                                     Text="{Binding Email2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <TextBlock Text="Email 3" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtEmail3"
                                     Text="{Binding Email3, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Margin="0,0,0,4">
                            <CheckBox x:Name="ChkAtivo"
                                      Content="Ativo?"
                                      IsChecked="{Binding Ativo}"
                                      Foreground="{StaticResource TextStrong}"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Card: Endereço -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Endereço do Fornecedor"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextStrong}"
                               Margin="0,0,0,14"/>

                    <!-- Linha 1: CEP, Logradouro, UF, Cidade -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="CEP" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtCep"
                                     Text="{Binding Cep, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Logradouro" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtLogradouro"
                                     Text="{Binding Logradouro, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <TextBlock Text="UF" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbUf"
                                      SelectedValue="{Binding Uf}"
                                      Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem Content="AC"/>
                                <ComboBoxItem Content="AL"/>
                                <ComboBoxItem Content="AM"/>
                                <ComboBoxItem Content="AP"/>
                                <ComboBoxItem Content="BA"/>
                                <ComboBoxItem Content="CE"/>
                                <ComboBoxItem Content="DF"/>
                                <ComboBoxItem Content="ES"/>
                                <ComboBoxItem Content="GO"/>
                                <ComboBoxItem Content="MA"/>
                                <ComboBoxItem Content="MG"/>
                                <ComboBoxItem Content="MS"/>
                                <ComboBoxItem Content="MT"/>
                                <ComboBoxItem Content="PA"/>
                                <ComboBoxItem Content="PB"/>
                                <ComboBoxItem Content="PE"/>
                                <ComboBoxItem Content="PI"/>
                                <ComboBoxItem Content="PR"/>
                                <ComboBoxItem Content="RJ"/>
                                <ComboBoxItem Content="RN"/>
                                <ComboBoxItem Content="RO"/>
                                <ComboBoxItem Content="RR"/>
                                <ComboBoxItem Content="RS"/>
                                <ComboBoxItem Content="SC"/>
                                <ComboBoxItem Content="SE"/>
                                <ComboBoxItem Content="SP"/>
                                <ComboBoxItem Content="TO"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Cidade" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtCidade"
                                     Text="{Binding Cidade, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Linha 2: Nº Endereço, Complemento -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Nº Endereço" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtNumeroEndereco"
                                     Text="{Binding NumeroEndereco, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Complemento do Endereço" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtComplemento"
                                     Text="{Binding Complemento, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Botões -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">

                        <Button x:Name="BtnSalvar"
                                Command="{Binding SalvarCommand}"
                                Height="40" Cursor="Hand"
                                Background="#16A34A" BorderThickness="0"
                                Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                        <StackPanel Orientation="Horizontal" Margin="16,0">
                                            <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16"
                                                                     Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Salvar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#15803D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnEditar"
                                Command="{Binding EditarCommand}"
                                Height="40" Cursor="Hand"
                                Background="#2563EB" BorderThickness="0"
                                Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                        <StackPanel Orientation="Horizontal" Margin="16,0">
                                            <materialDesign:PackIcon Kind="PencilOutline" Width="16" Height="16"
                                                                     Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Editar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1D4ED8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnLimpar"
                                Command="{Binding LimparCommand}"
                                Height="40" Cursor="Hand"
                                Background="#F59E0B" BorderThickness="0"
                                Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                        <StackPanel Orientation="Horizontal" Margin="16,0">
                                            <materialDesign:PackIcon Kind="Broom" Width="16" Height="16"
                                                                     Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Limpar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D97706"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnDeletar"
                                Command="{Binding DeletarCommand}"
                                Height="40" Cursor="Hand"
                                Background="#DC2626" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                        <StackPanel Orientation="Horizontal" Margin="16,0">
                                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16"
                                                                     Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Deletar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#B91C1C"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Lista de Fornecedores -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header + Filtro -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Lista de Fornecedores"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextStrong}"/>
                        <TextBlock Text="Selecione um item para editar, ou use as ações da linha."
                                   Margin="0,4,0,0" FontSize="12"
                                   Foreground="{StaticResource TextSoft}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Filtrar por Nome" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtFiltroNome"
                                 Text="{Binding FiltroNome, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="DgFornecedores"
                          Grid.Row="2"
                          Style="{StaticResource CleanDataGrid}"
                          ItemsSource="{Binding Fornecedores}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CPF/CNPJ"  Binding="{Binding CpfCnpj}"   Width="140"/>
                        <DataGridTextColumn Header="Nome"       Binding="{Binding Nome}"       Width="*"/>
                        <DataGridTextColumn Header="Telefone"   Binding="{Binding Telefone1}"  Width="130"/>
                        <DataGridTextColumn Header="Email"      Binding="{Binding Email1}"     Width="*"/>
                        <DataGridTextColumn Header="Ativo"      Binding="{Binding Ativo}"      Width="70"/>
                        <DataGridTextColumn Header="CEP"        Binding="{Binding Cep}"        Width="100"/>
                        <DataGridTextColumn Header="UF"         Binding="{Binding Uf}"         Width="60"/>
                        <DataGridTextColumn Header="Cidade"     Binding="{Binding Cidade}"     Width="130"/>

                        <DataGridTemplateColumn Header="Ações" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Width="30" Height="30" Margin="0,0,8,0"
                                                Background="#EEF2FF" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.EditarLinhaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="PencilOutline" Width="16" Height="16" Foreground="#4F46E5"/>
                                        </Button>
                                        <Button Width="30" Height="30"
                                                Background="#FEE2E2" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.ExcluirLinhaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16" Foreground="#DC2626"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>

    </Grid>
</UserControl>
