<Window x:Class="GerenciamentoDeFrota.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Gerenciamento de Frota"
        Height="850" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>

        <SolidColorBrush x:Key="AppSurfaceBrush"        Color="#F5F7FB"/>
        <SolidColorBrush x:Key="PanelBrush"             Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LogoHolderBrush"        Color="#30FFFFFF"/>
        <SolidColorBrush x:Key="SidebarTitleBrush"      Color="#0F3D2E"/>
        <SolidColorBrush x:Key="SidebarSubTitleBrush"   Color="#2E6B57"/>
        <SolidColorBrush x:Key="NavHoverBrush"          Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="NavPressedBrush"        Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="NavSelectedBrush"       Color="#300F3D2E"/>
        <SolidColorBrush x:Key="NavSelectedBorderBrush" Color="#450F3D2E"/>

        <LinearGradientBrush x:Key="SidebarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D7FBEA" Offset="0"/>
            <GradientStop Color="#8CE7B7" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid Margin="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource SidebarTitleBrush}"
                                           Text="{TemplateBinding Tag}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NavHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NavPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NavSelectedBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource NavSelectedBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubNavItemStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid Margin="10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource SidebarTitleBrush}"
                                           Text="{TemplateBinding Tag}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NavHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NavPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NavSelectedBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource NavSelectedBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GroupToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid Margin="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="22"/>
                                </Grid.ColumnDefinitions>

                                <materialDesign:PackIcon Grid.Column="0"
                                    Kind="FolderMultipleOutline" Width="22" Height="22"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Foreground="{StaticResource SidebarTitleBrush}"/>

                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource SidebarTitleBrush}"
                                           Text="Cadastros Gerais"/>

                                <materialDesign:PackIcon x:Name="Arrow"
                                    Grid.Column="2" Kind="ChevronDown"
                                    Width="16" Height="16" VerticalAlignment="Center"
                                    Foreground="{StaticResource SidebarTitleBrush}">
                                    <materialDesign:PackIcon.RenderTransform>
                                        <RotateTransform x:Name="ArrowRotate" Angle="0" CenterX="8" CenterY="8"/>
                                    </materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NavHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NavPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NavSelectedBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource NavSelectedBorderBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ArrowRotate"
                                                             Storyboard.TargetProperty="Angle"
                                                             To="180" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ArrowRotate"
                                                             Storyboard.TargetProperty="Angle"
                                                             To="0" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Border raiz com o botão fechar sobreposto via Grid -->
    <Border CornerRadius="25"
            Background="{StaticResource AppSurfaceBrush}"
            MouseDown="Border_MouseDown"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>

            <!-- Botão fechar — ZIndex alto para ficar sobre tudo -->
            <Button x:Name="BtnFechar"
                    Click="BtnFechar_Click"
                    Width="32" Height="32"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,12,0"
                    Panel.ZIndex="99"
                    Background="#FFEBEB"
                    BorderThickness="0"
                    Cursor="Hand" RenderTransformOrigin="0.844,-0.125">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"
                                                     Foreground="#DC2626"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FCA5A5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Layout principal -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0"
                        Background="{StaticResource SidebarBrush}"
                        CornerRadius="25,0,0,25">

                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- LOGO + NOME -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top">
                            <Border Width="66" Height="66" CornerRadius="33"
                                    Background="{StaticResource LogoHolderBrush}">
                                <Ellipse Margin="8">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="pack://application:,,,/Assets/Images/logo_ecofrota.png"
                                                    Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Border>
                            <StackPanel Margin="12,6,0,0">
                                <TextBlock x:Name="TxtEmpresa" Text="ECOFROTA"
                                           Foreground="{StaticResource SidebarTitleBrush}"
                                           FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Gerenciamento de Frota"
                                           Foreground="{StaticResource SidebarSubTitleBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Row="2" Height="1" Background="#22FFFFFF"/>

                        <!-- MENU -->
                        <StackPanel Grid.Row="4" x:Name="MenuContainer" Margin="0,18,0,0">

                            <!-- Dashboard -->
                            <RadioButton x:Name="RbDashboard"
                                         GroupName="Nav"
                                         Style="{StaticResource NavItemStyle}"
                                         Tag="Dashboard"
                                         IsChecked="True"
                                         Checked="RbDashboard_Checked"
                                         Margin="0,0,0,6">
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="22" Height="22"
                                                         Foreground="{StaticResource SidebarTitleBrush}"/>
                            </RadioButton>

                            <!-- Grupo Cadastros Gerais -->
                            <ToggleButton x:Name="TglCadastros"
                                          Style="{StaticResource GroupToggleStyle}"
                                          Margin="0,0,0,2"/>

                            <!-- Sub-itens -->
                            <StackPanel Margin="16,0,0,6">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=TglCadastros}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#44FFFFFF" CornerRadius="1" Margin="8,4,0,4"/>

                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">

                                        <RadioButton x:Name="RbVeiculos"
                                                     GroupName="Nav"
                                                     Style="{StaticResource SubNavItemStyle}"
                                                     Tag="Veículos"
                                                     Checked="RbVeiculos_Checked">
                                            <materialDesign:PackIcon Kind="CarOutline" Width="16" Height="16"
                                                                     Foreground="{StaticResource SidebarTitleBrush}"/>
                                        </RadioButton>

                                        <RadioButton x:Name="RbCondutores"
                                                     GroupName="Nav"
                                                     Style="{StaticResource SubNavItemStyle}"
                                                     Tag="Condutores"
                                                     Checked="RbCondutores_Checked">
                                            <materialDesign:PackIcon Kind="AccountTieOutline" Width="16" Height="16"
                                                                     Foreground="{StaticResource SidebarTitleBrush}"/>
                                        </RadioButton>

                                        <RadioButton x:Name="RbCentrosCusto"
                                                     GroupName="Nav"
                                                     Style="{StaticResource SubNavItemStyle}"
                                                     Tag="Centros de Custo"
                                                     Checked="RbCentrosCusto_Checked">
                                            <materialDesign:PackIcon Kind="CurrencyUsd" Width="16" Height="16"
                                                                     Foreground="{StaticResource SidebarTitleBrush}"/>
                                        </RadioButton>

                                        <RadioButton x:Name="RbFornecedores"
                                                     GroupName="Nav"
                                                     Style="{StaticResource SubNavItemStyle}"
                                                     Tag="Fornecedores"
                                                     Checked="RbFornecedores_Checked">
                                            <materialDesign:PackIcon Kind="TruckOutline" Width="16" Height="16"
                                                                     Foreground="{StaticResource SidebarTitleBrush}"/>
                                        </RadioButton>

                                        <RadioButton x:Name="RbCombustivel"
                                                     GroupName="Nav"
                                                     Style="{StaticResource SubNavItemStyle}"
                                                     Tag="Combustíveis"
                                                     Checked="RbCombustivel_Checked">
                                            <materialDesign:PackIcon Kind="GasStation" Width="16" Height="16"
                                                                     Foreground="{StaticResource SidebarTitleBrush}"/>
                                        </RadioButton>

                                        <RadioButton x:Name="RbVeiculoCombustivel"
                                                     GroupName="Nav"
                                                     Style="{StaticResource SubNavItemStyle}"
                                                     Tag="Veículo/Combustível"
                                                     Checked="RbVeiculoCombustivel_Checked">
                                            <materialDesign:PackIcon Kind="CarCog" Width="16" Height="16"
                                                                     Foreground="{StaticResource SidebarTitleBrush}"/>
                                        </RadioButton>

                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Agendamento -->
                            <RadioButton x:Name="RbAgendamento"
                                         GroupName="Nav"
                                         Style="{StaticResource NavItemStyle}"
                                         Tag="Agendamento"
                                         Checked="RbAgendamento_Checked"
                                         Margin="0,6,0,0">
                                <materialDesign:PackIcon Kind="CalendarClock" Width="22" Height="22"
                                                         Foreground="{StaticResource SidebarTitleBrush}"/>
                            </RadioButton>

                        </StackPanel>

                        <StackPanel Grid.Row="5" x:Name="SidebarFooter"/>
                    </Grid>
                </Border>

                <!-- ÁREA PRINCIPAL (DIREITA) -->
                <Border Grid.Column="1"
                        Background="{StaticResource AppSurfaceBrush}"
                        CornerRadius="0,25,25,0"
                        Padding="22">
                    <Border Background="{StaticResource PanelBrush}"
                            CornerRadius="18" Padding="18">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ContentControl x:Name="MainContentHost"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch"/>
                        </ScrollViewer>
                    </Border>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
