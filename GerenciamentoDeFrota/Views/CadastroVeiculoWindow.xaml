<Window x:Class="GerenciamentoDeFrota.Views.CadastroVeiculoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Cadastro de Veículo"
        Width="720" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextStrong" Color="#1F2A37"/>
        <SolidColorBrush x:Key="TextSoft"   Color="#6B7280"/>
        <SolidColorBrush x:Key="LineBrush"  Color="#E5E7EB"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernTextBoxMultiline" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Height" Value="80"/>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsEditable" Value="False"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoft}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20"
            Background="{StaticResource CardBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            MouseDown="Border_MouseDown">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="Novo Veículo"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextStrong}"/>
                    <TextBlock Text="Preencha os dados do veículo abaixo."
                               FontSize="12" Foreground="{StaticResource TextSoft}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="BtnFechar_Click"
                        Width="28" Height="28"
                        Background="#FFEBEB" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                <materialDesign:PackIcon Kind="Close" Width="14" Height="14"
                                                         Foreground="#DC2626"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FCA5A5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="{StaticResource LineBrush}" Margin="0,8,0,0"/>

            <!-- Identificação -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="Identificação"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextStrong}"
                           Margin="0,0,0,12"/>

                <!-- Linha 1: Fabricante | Modelo | Placa | Renavam -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.4*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Fabricante *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Fabricante, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Modelo *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Modelo, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Placa *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Placa, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 TextChanged="TxtPlaca_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Renavam" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Renavam, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 PreviewTextInput="TxtRenavam_PreviewTextInput"/>
                    </StackPanel>
                </Grid>

                <!-- Linha 2: Tipo de Veículo | KM Atual -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Tipo de Veículo" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding TiposVeiculo}"
                                  SelectedItem="{Binding Tipo, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource ModernComboBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="KM/Horímetro Atual" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding KmAtual, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 PreviewTextInput="TxtKmAtual_PreviewTextInput"
                                 TextChanged="TxtKmAtual_TextChanged"/>
                    </StackPanel>

                    <!-- Coluna vazia para equilíbrio visual -->
                    <Grid Grid.Column="2"/>
                </Grid>
            </StackPanel>

            <!-- Informações Complementares -->
            <StackPanel Grid.Row="4">
                <TextBlock Text="Informações Complementares"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextStrong}"
                           Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Ano Modelo" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding AnoModelo, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 PreviewTextInput="TxtAnoModelo_PreviewTextInput"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Ano Fabricação" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding AnoFabricacao, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 PreviewTextInput="TxtAnoFabricacao_PreviewTextInput"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Mês Emplacamento" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding MesEmplacamento, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 PreviewTextInput="TxtMesEmplacamento_PreviewTextInput"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                        <TextBlock Text="Cor" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Cor, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Venc. Tacógrafo" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding DataTacografo}"
                                    Height="32" FontSize="13"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    SelectedDateFormat="Short"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Observações + Ativo -->
            <StackPanel Grid.Row="6">
                <TextBlock Text="Observações" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBoxMultiline}"/>
                <CheckBox Content="Ativo?"
                          IsChecked="{Binding Ativo}"
                          Foreground="{StaticResource TextStrong}"
                          Margin="0,12,0,0"/>
            </StackPanel>

            <!-- Mensagem de erro -->
            <TextBlock Grid.Row="7"
                       Text="{Binding MensagemErro}"
                       Foreground="#DC2626" FontSize="12"/>

            <!-- Botões -->
            <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding DeletarCommand}"
                        Height="40" Cursor="Hand"
                        Background="#DC2626" BorderThickness="0"
                        Margin="0,0,8,0"
                        Visibility="{Binding EmModoEdicao, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <StackPanel Orientation="Horizontal" Margin="16,0">
                                    <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16"
                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Deletar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#B91C1C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>



                <Button Command="{Binding CancelarCommand}"
                        Height="40" Cursor="Hand"
                        Background="#F3F4F6" BorderThickness="0"
                        Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <StackPanel Orientation="Horizontal" Margin="16,0">
                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"
                                                             Foreground="{StaticResource TextStrong}"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Cancelar" Foreground="{StaticResource TextStrong}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E7EB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Command="{Binding LimparCommand}"
                        Height="40" Cursor="Hand"
                        Background="#F59E0B" BorderThickness="0"
                        Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <StackPanel Orientation="Horizontal" Margin="16,0">
                                    <materialDesign:PackIcon Kind="Broom" Width="16" Height="16"
                                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Limpar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D97706"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Command="{Binding SalvarCommand}"
                        Height="40" Cursor="Hand"
                        Background="#16A34A" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <StackPanel Orientation="Horizontal" Margin="16,0">
                                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16"
                                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Salvar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#15803D"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</Window>
