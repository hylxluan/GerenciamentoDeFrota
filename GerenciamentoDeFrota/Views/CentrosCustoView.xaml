<UserControl x:Class="GerenciamentoDeFrota.Views.CentrosCustoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <UserControl.Resources>

        <SolidColorBrush x:Key="CardBrush"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextStrong" Color="#1F2A37"/>
        <SolidColorBrush x:Key="TextSoft"   Color="#6B7280"/>
        <SolidColorBrush x:Key="LineBrush"  Color="#E5E7EB"/>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernTextBoxMultiline" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Height" Value="110"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoft}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="CleanDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="42"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FBFBFD"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="2,2,2,14">
            <TextBlock Text="Cadastro de Centros de Custo"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextStrong}"/>
            <TextBlock Text="Gerencie os centros de custo da sua frota."
                       Margin="0,4,0,0" FontSize="12"
                       Foreground="{StaticResource TextSoft}"/>
        </StackPanel>

        <!-- FORM -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Informações do Centro de Custo"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextStrong}"
                           Margin="0,0,0,14"/>

                <!-- Nome -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Nome do Centro de Custo" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtNome"
                             Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Width="320"
                             HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Observações -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Observações / Detalhamento" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtObservacoes"
                             Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxMultiline}"/>
                </StackPanel>

                <!-- Ativo -->
                <CheckBox x:Name="ChkAtivo"
                          Content="Ativo?"
                          IsChecked="{Binding Ativo}"
                          Foreground="{StaticResource TextStrong}"
                          Margin="0,0,0,16"/>

                <!-- Mensagens -->
                <TextBlock Text="{Binding MensagemErro}"
                           Foreground="#DC2626" FontSize="12"
                           Margin="0,0,0,8"/>
                <TextBlock Text="{Binding MensagemSucesso}"
                           Foreground="#16A34A" FontSize="12"
                           Margin="0,0,0,8"/>

                <!-- Botões -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button x:Name="BtnSalvar"
                            Command="{Binding SalvarCommand}"
                            Height="40" Cursor="Hand"
                            Background="#16A34A" BorderThickness="0"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                    <StackPanel Orientation="Horizontal" Margin="16,0">
                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16"
                                                                 Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Salvar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#15803D"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="BtnEditar"
                            Command="{Binding EditarCommand}"
                            Height="40" Cursor="Hand"
                            Background="#2563EB" BorderThickness="0"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                    <StackPanel Orientation="Horizontal" Margin="16,0">
                                        <materialDesign:PackIcon Kind="PencilOutline" Width="16" Height="16"
                                                                 Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Editar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1D4ED8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="BtnLimpar"
                            Command="{Binding LimparCommand}"
                            Height="40" Cursor="Hand"
                            Background="#F59E0B" BorderThickness="0"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                    <StackPanel Orientation="Horizontal" Margin="16,0">
                                        <materialDesign:PackIcon Kind="Broom" Width="16" Height="16"
                                                                 Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Limpar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D97706"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="BtnDeletar"
                            Command="{Binding DeletarCommand}"
                            Height="40" Cursor="Hand"
                            Background="#DC2626" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                    <StackPanel Orientation="Horizontal" Margin="16,0">
                                        <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16"
                                                                 Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Deletar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#B91C1C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Lista -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Lista de Centros de Custo"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextStrong}"/>
                        <TextBlock Text="Selecione um item para editar ou deletar."
                                   Margin="0,4,0,0" FontSize="12"
                                   Foreground="{StaticResource TextSoft}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Filtrar por Nome" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtFiltroNome"
                                 Text="{Binding FiltroNome, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="DgCentrosCusto"
                          Grid.Row="2"
                          Style="{StaticResource CleanDataGrid}"
                          ItemsSource="{Binding CentrosCusto}"
                          SelectedItem="{Binding Selecionado}"
                          IsReadOnly="True"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Código"
                                            Binding="{Binding Id}"
                                            Width="70"/>

                        <DataGridTextColumn Header="Nome"
                                            Binding="{Binding Nome}"
                                            Width="*"/>

                        <DataGridTemplateColumn Header="Ativo" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Ativo, Mode=OneWay}"
                                              IsEnabled="False"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Observações"
                                            Binding="{Binding Observacoes}"
                                            Width="2*"/>


                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>

    </Grid>
</UserControl>
