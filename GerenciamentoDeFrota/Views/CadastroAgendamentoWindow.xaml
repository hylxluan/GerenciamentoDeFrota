<Window x:Class="GerenciamentoDeFrota.Views.CadastroAgendamentoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Novo Agendamento"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextStrong" Color="#1F2A37"/>
        <SolidColorBrush x:Key="TextSoft"   Color="#6B7280"/>
        <SolidColorBrush x:Key="LineBrush"  Color="#E5E7EB"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height"                Value="32"/>
            <Setter Property="Padding"               Value="6,4"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="Foreground"            Value="{StaticResource TextStrong}"/>
            <Setter Property="Background"            Value="#FFFFFF"/>
            <Setter Property="BorderBrush"           Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernTextBoxMultiline" TargetType="TextBox">
            <Setter Property="Padding"               Value="6,4"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="Foreground"            Value="{StaticResource TextStrong}"/>
            <Setter Property="Background"            Value="#FFFFFF"/>
            <Setter Property="BorderBrush"           Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="AcceptsReturn"         Value="True"/>
            <Setter Property="TextWrapping"          Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Height"                Value="70"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoft}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- Item do autocomplete -->
        <Style x:Key="AutocompleteItem" TargetType="ListBoxItem">
            <Setter Property="Padding"     Value="10,8"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Foreground"  Value="{StaticResource TextStrong}"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0FDF4"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCFCE7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20"
            Background="{StaticResource CardBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            MouseDown="Border_MouseDown">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 0  Header         -->
                <RowDefinition Height="16"/>
                <!-- 1  sep            -->
                <RowDefinition Height="Auto"/>
                <!-- 2  Veículo        -->
                <RowDefinition Height="14"/>
                <!-- 3  gap            -->
                <RowDefinition Height="Auto"/>
                <!-- 4  Data + Horário -->
                <RowDefinition Height="14"/>
                <!-- 5  gap            -->
                <RowDefinition Height="Auto"/>
                <!-- 6  Serviço        -->
                <RowDefinition Height="Auto"/>
                <!-- 7  KM (condicional)-->
                <RowDefinition Height="14"/>
                <!-- 8  gap            -->
                <RowDefinition Height="Auto"/>
                <!-- 9  Observações    -->
                <RowDefinition Height="Auto"/>
                <!-- 10 Erro           -->
                <RowDefinition Height="16"/>
                <!-- 11 gap botões     -->
                <RowDefinition Height="Auto"/>
                <!-- 12 Botões         -->
            </Grid.RowDefinitions>

            <!-- ── HEADER ──────────────────────────────────────────────────── -->
            <Grid Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="Novo Agendamento"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextStrong}"/>
                    <TextBlock Text="Preencha os dados do agendamento de manutenção."
                               FontSize="12" Foreground="{StaticResource TextSoft}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="BtnFechar_Click"
                        Width="28" Height="28"
                        Background="#FFEBEB" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                <materialDesign:PackIcon Kind="Close" Width="14" Height="14"
                                                         Foreground="#DC2626"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FCA5A5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="{StaticResource LineBrush}" Margin="0,8,0,0"/>

            <!-- ── VEÍCULO (autocomplete) ──────────────────────────────────── -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="Veículo *" Style="{StaticResource FieldLabel}"/>

                <!-- Container relativo para o Popup ficar ancorado -->
                <Grid x:Name="GridVeiculo">
                    <TextBox x:Name="TxtBuscaVeiculo"
                             Text="{Binding TextoBuscaVeiculo, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             GotFocus="TxtBuscaVeiculo_GotFocus"
                             PreviewKeyDown="TxtBuscaVeiculo_PreviewKeyDown"/>

                    <!-- Ícone de busca dentro do TextBox -->
                    <materialDesign:PackIcon Kind="Magnify"
                                             Width="16" Height="16"
                                             Foreground="{StaticResource TextSoft}"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"
                                             IsHitTestVisible="False"/>

                    <!-- Popup de sugestões -->
                    <Popup x:Name="PopupSugestoes"
                           IsOpen="{Binding PopupVeiculoAberto, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=TxtBuscaVeiculo}"
                           Placement="Bottom"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           PopupAnimation="Slide"
                           Width="{Binding ActualWidth, ElementName=GridVeiculo}">
                        <Border Background="White"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,2,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                                                  Opacity="0.12" Direction="270"/>
                            </Border.Effect>
                            <ListBox x:Name="ListSugestoes"
                                     ItemsSource="{Binding VeiculosFiltrados}"
                                     SelectedItem="{Binding VeiculoSelecionado}"
                                     ItemContainerStyle="{StaticResource AutocompleteItem}"
                                     DisplayMemberPath="VeiculoDescricao"
                                     MaxHeight="200"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     PreviewMouseLeftButtonDown="ListSugestoes_PreviewMouseLeftButtonDown"/>
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>

            <!-- ── DATA + HORÁRIO ──────────────────────────────────────────── -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Data *" Style="{StaticResource FieldLabel}"/>
                    <DatePicker SelectedDate="{Binding DataAgendamento}"
                                Height="32" FontSize="13"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                SelectedDateFormat="Short"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Horário * (HH:mm)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Horario, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             PreviewTextInput="TxtHorario_PreviewTextInput"
                             MaxLength="5"/>
                </StackPanel>
            </Grid>

            <!-- ── SERVIÇO ─────────────────────────────────────────────────── -->
            <StackPanel Grid.Row="6" Margin="0,0,0,14">
                <TextBlock Text="Serviço a Realizar *" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Servico, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"/>
            </StackPanel>

            <!-- ── KM / HORÍMETRO — só aparece após selecionar veículo ──────── -->
            <StackPanel Grid.Row="7"
                        Margin="0,0,0,14"
                        Visibility="{Binding VeiculoFoiSelecionado, Converter={StaticResource BoolToVis}}">
                <TextBlock Style="{StaticResource FieldLabel}">
                    <Run Text="KM / Horímetro Atual"/>
                    <Run Text="  (leitura no momento do agendamento)"
                         Foreground="#9CA3AF" FontSize="11"/>
                </TextBlock>

                <!-- Campo com prefixo "KM" e máscara de milhar -->
                <Border CornerRadius="6"
                        BorderBrush="#86EFAC" BorderThickness="1"
                        Background="#F0FDF4"
                        Height="32">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#DCFCE7"
                                CornerRadius="5,0,0,5"
                                Padding="10,0">
                            <TextBlock Text="KM" FontSize="12" FontWeight="Bold"
                                       Foreground="#16A34A"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBox Grid.Column="1"
                                 x:Name="TxtKmAtualAgendamento"
                                 Text="{Binding KmAtualDisplay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="#166534"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 PreviewTextInput="TxtKmAtualAgendamento_PreviewTextInput"
                                 TextChanged="TxtKmAtualAgendamento_TextChanged"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ── OBSERVAÇÕES ─────────────────────────────────────────────── -->
            <StackPanel Grid.Row="9">
                <TextBlock Text="Observações" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBoxMultiline}"/>
            </StackPanel>

            <!-- ── MENSAGEM ERRO ───────────────────────────────────────────── -->
            <TextBlock Grid.Row="10"
                       Text="{Binding MensagemErro}"
                       Foreground="#DC2626" FontSize="12"
                       Margin="0,8,0,0"
                       Visibility="{Binding TemErro, Converter={StaticResource BoolToVis}}"/>

            <!-- ── BOTÕES ──────────────────────────────────────────────────── -->
            <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">

                <Button Command="{Binding CancelarCommand}"
                        Height="40" Cursor="Hand"
                        Background="#F3F4F6" BorderThickness="0"
                        Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <StackPanel Orientation="Horizontal" Margin="16,0">
                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"
                                                             Foreground="{StaticResource TextStrong}"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Cancelar" Foreground="{StaticResource TextStrong}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E7EB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Command="{Binding LimparCommand}"
                        Height="40" Cursor="Hand"
                        Background="#F59E0B" BorderThickness="0"
                        Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <StackPanel Orientation="Horizontal" Margin="16,0">
                                    <materialDesign:PackIcon Kind="Broom" Width="16" Height="16"
                                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Limpar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D97706"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Command="{Binding SalvarCommand}"
                        Height="40" Cursor="Hand"
                        Background="#16A34A" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <StackPanel Orientation="Horizontal" Margin="16,0">
                                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16"
                                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Salvar" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#15803D"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</Window>
